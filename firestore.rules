rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin';
    }

    function canManageExams() {
      return signedIn()
        && (
          isAdmin()
          || (
            exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
            && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.puedeGestionarExamenes == true
          )
        );
    }

    function userIsAdmin(uid) {
      return uid is string
        && exists(/databases/$(database)/documents/usuarios/$(uid))
        && get(/databases/$(database)/documents/usuarios/$(uid)).data.rol == 'admin';
    }

    function isValidRole(value) {
      return value is string && (value == 'admin' || value == 'usuario');
    }

    function validUsuarioData(data, uid) {
      return data.uid == uid
        && data.nombre is string && data.nombre.size() <= 80
        && data.email is string && data.email.size() <= 120
        && data.activo is bool
        && isValidRole(data.rol)
        && data.puedeGestionarExamenes is bool
        && data.keys().hasOnly([
          'uid',
          'nombre',
          'email',
          'activo',
          'rol',
          'puedeGestionarExamenes',
          'createdAt',
          'updatedAt'
        ]);
    }

    function validSolicitudPermisoData(data) {
      return data.uid is string && data.uid.size() > 0
        && data.nombre is string && data.nombre.size() <= 80
        && data.email is string && data.email.size() <= 120
        && data.estado is string && (data.estado == 'pendiente' || data.estado == 'aprobada' || data.estado == 'rechazada')
        && (!('revisadoPorUid' in data) || data.revisadoPorUid is string)
        && data.keys().hasOnly([
          'uid',
          'nombre',
          'email',
          'estado',
          'revisadoPorUid',
          'createdAt',
          'updatedAt'
        ]);
    }

    function validExamenData(data) {
      return data.titulo is string && data.titulo.size() > 0 && data.titulo.size() <= 120
        && data.descripcion is string && data.descripcion.size() <= 500
        && data.creadoPorUid is string && data.creadoPorUid.size() > 0
        && data.creadoPorNombre is string && data.creadoPorNombre.size() <= 80
        && data.creadoPorEmail is string && data.creadoPorEmail.size() <= 120
        && data.estadoRevision is string && (data.estadoRevision == 'pendiente' || data.estadoRevision == 'aprobado' || data.estadoRevision == 'rechazado')
        && data.revisadoPorUid is string && data.revisadoPorUid.size() <= 128
        && data.totalPreguntas is int && data.totalPreguntas >= 1 && data.totalPreguntas <= 5
        && data.activo is bool
        && data.keys().hasOnly([
          'titulo',
          'descripcion',
          'creadoPorUid',
          'creadoPorNombre',
          'creadoPorEmail',
          'estadoRevision',
          'revisadoPorUid',
          'totalPreguntas',
          'activo',
          'createdAt',
          'updatedAt'
        ]);
    }

    function validPreguntaData(data) {
      return data.texto is string && data.texto.size() > 0 && data.texto.size() <= 280
        && data.correctaIndex is int && data.correctaIndex >= 0 && data.correctaIndex <= 3
        && data.orden is int && data.orden >= 1 && data.orden <= 5
        && data.respuestas is list
        && data.respuestas.size() == 4
        && data.respuestas[0] is string && data.respuestas[0].size() > 0 && data.respuestas[0].size() <= 180
        && data.respuestas[1] is string && data.respuestas[1].size() > 0 && data.respuestas[1].size() <= 180
        && data.respuestas[2] is string && data.respuestas[2].size() > 0 && data.respuestas[2].size() <= 180
        && data.respuestas[3] is string && data.respuestas[3].size() > 0 && data.respuestas[3].size() <= 180
        && data.keys().hasOnly(['texto', 'respuestas', 'correctaIndex', 'orden', 'createdAt']);
    }

    function validCalificacionData(data) {
      return data.uid is string && data.uid.size() > 0
        && data.nombre is string && data.nombre.size() <= 80
        && data.email is string && data.email.size() <= 120
        && data.examenId is string && data.examenId.size() > 0
        && data.examenTitulo is string && data.examenTitulo.size() > 0 && data.examenTitulo.size() <= 120
        && data.totalPreguntas is int && data.totalPreguntas >= 1 && data.totalPreguntas <= 100
        && data.correctas is int && data.correctas >= 0 && data.correctas <= data.totalPreguntas
        && data.incorrectas is int && data.incorrectas >= 0 && data.incorrectas <= data.totalPreguntas
        && data.correctas + data.incorrectas == data.totalPreguntas
        && data.porcentaje is int && data.porcentaje >= 0 && data.porcentaje <= 100
        && data.tiempoSegundos is int && data.tiempoSegundos >= 0 && data.tiempoSegundos <= 86400
        && data.tiempoTexto is string && data.tiempoTexto.size() >= 8 && data.tiempoTexto.size() <= 12
        && data.keys().hasOnly([
          'uid',
          'nombre',
          'email',
          'examenId',
          'examenTitulo',
          'totalPreguntas',
          'correctas',
          'incorrectas',
          'porcentaje',
          'tiempoSegundos',
          'tiempoTexto',
          'createdAt'
        ]);
    }

    match /usuarios/{uid} {
      allow create: if (isOwner(uid) || isAdmin())
        && validUsuarioData(request.resource.data, uid)
        && request.resource.data.uid == uid;
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      allow update: if validUsuarioData(request.resource.data, uid)
        && (
          isAdmin()
          || (
            isOwner(uid)
            && request.resource.data.rol == resource.data.rol
            && request.resource.data.activo == resource.data.activo
            && request.resource.data.puedeGestionarExamenes == resource.data.puedeGestionarExamenes
          )
        );
      allow delete: if isAdmin();
    }

    match /examenes/{examId} {
      allow create: if canManageExams()
        && validExamenData(request.resource.data)
        && request.resource.data.creadoPorUid == request.auth.uid
        && (
          isAdmin()
          || (
            request.resource.data.estadoRevision == 'pendiente'
            && request.resource.data.revisadoPorUid == ''
          )
        );
      allow get, list: if signedIn()
        && (
          isAdmin()
          || resource.data.creadoPorUid == request.auth.uid
          || resource.data.estadoRevision == 'aprobado'
        );
      allow update, delete: if canManageExams()
        && validExamenData(request.resource.data)
        && (
          isAdmin()
          || resource.data.creadoPorUid == request.auth.uid
        )
        && (
          isAdmin()
          || (
            request.resource.data.estadoRevision == 'pendiente'
            && request.resource.data.revisadoPorUid == ''
          )
        )
        && request.resource.data.creadoPorUid == resource.data.creadoPorUid
        && request.resource.data.creadoPorEmail == resource.data.creadoPorEmail
        && request.resource.data.createdAt == resource.data.createdAt;

      match /preguntas/{questionId} {
        allow create, update, delete: if canManageExams()
          && validPreguntaData(request.resource.data)
          && (
            isAdmin()
            || get(/databases/$(database)/documents/examenes/$(examId)).data.creadoPorUid == request.auth.uid
          );
        allow get, list: if signedIn()
          && (
            isAdmin()
            || get(/databases/$(database)/documents/examenes/$(examId)).data.creadoPorUid == request.auth.uid
            || get(/databases/$(database)/documents/examenes/$(examId)).data.estadoRevision == 'aprobado'
          );
      }
    }

    match /solicitudesPermisoExamenes/{requestId} {
      allow create: if signedIn()
        && validSolicitudPermisoData(request.resource.data)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.estado == 'pendiente';
      allow get, list: if isAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
      allow update: if isAdmin()
        && validSolicitudPermisoData(request.resource.data)
        && request.resource.data.uid == resource.data.uid;
      allow delete: if isAdmin();
    }

    match /calificaciones/{resultId} {
      allow create: if signedIn()
        && validCalificacionData(request.resource.data)
        && request.resource.data.uid == request.auth.uid;
      allow get, list: if isAdmin() || (signedIn() && resource.data.uid == request.auth.uid);
      allow update: if false;
      allow delete: if isAdmin();
    }
  }
}
